# --- Environment Variables for Nuxt 3 Application ---
NODE_ENV=production
NUXT_DEVTOOLS=false

# --- API CONFIGURATION ---
# Public URL used by the browser (client-side)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1

# Private URL used by Nuxt Nitro (server-side SSR)
# In Docker, use the service name (e.g., http://backend:8080/v1)
# On Linux Docker with host network, use http://172.17.0.1:8080/v1 or host.docker.internal
# Defaults to NUXT_PUBLIC_API_BASE_URL if not set.
NUXT_API_BASE_URL_SERVER=http://localhost:8080/v1

# --- EXAMPLES ---
# Docker Compose (same network):
# NUXT_API_BASE_URL_SERVER=http://backend:8080/v1
# NUXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1

# Production (with proxy):
# NUXT_API_BASE_URL_SERVER=https://api.example.com/v1
# NUXT_PUBLIC_API_BASE_URL=https://api.example.com/v1
